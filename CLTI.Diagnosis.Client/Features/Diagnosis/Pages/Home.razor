@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web

<div class="page-container">
    <NavMenuHome />

    <div class="home-content">
        <div class="search-row">
            <input class="search-input"
                   placeholder="Пошук по ПІБ, номеру кейсу, кроку"
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>

        <div class="split-layout">
        <div class="cases-column">
            <div class="section-title">In progress cases</div>
            @if (isLoading)
            {
                <div class="state-message">Loading cases...</div>
            }
            else if (!OpenCases.Any())
            {
                <div class="state-message">No in-progress cases.</div>
            }
            else
            {
                <div class="cases-grid">
                    @foreach (var caseItem in OpenCasesFiltered)
                    {
                        <div class="case-card" @onclick="@((MouseEventArgs e) => OpenContextMenu(e.ClientX, e.ClientY, caseItem))">
                            <div class="case-card-title">@caseItem.PatientFullName</div>
                            <div class="case-card-subtitle">@GetLastStepDisplay(caseItem)</div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="layout-separator"></div>

        <div class="cases-column">
            <div class="section-title">Done cases</div>
            @if (isLoading)
            {
                <div class="state-message">Loading cases...</div>
            }
            else if (!DoneCases.Any())
            {
                <div class="state-message">No done cases.</div>
            }
            else
            {
                <div class="cases-grid">
                    @foreach (var caseItem in DoneCasesFiltered)
                    {
                        <div class="case-card" @onclick="@((MouseEventArgs e) => OpenContextMenu(e.ClientX, e.ClientY, caseItem))">
                            <div class="case-card-title">@caseItem.PatientFullName</div>
                            <div class="case-card-subtitle">@GetLastStepDisplay(caseItem)</div>
                        </div>
                    }
                </div>
            }
        </div>
        </div>
    </div>

    <ContextMenu @ref="contextMenuRef"
                 OnViewCase="HandleOpenCase"
                 OnDeleteCase="HandleDeleteCase" />
</div>
